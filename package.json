{
  "name": "ucw",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const execPath = process.env.npm_execpath || ''; if (!execPath.includes('pnpm')) { console.error('Use pnpm to install dependencies.'); process.exit(1); }\"",
    "sandcastle": "tsx .sandcastle/main.ts",
    "guidesite:mvp": "tsx src/guidesite-mvp/cli.ts",
    "workbench": "tsx src/retrieval-workbench/cli.ts",
    "workbench:generate": "tsx src/retrieval-workbench/generate-fixture.ts",
    "check": "pnpm typecheck && pnpm build:gui",
    "typecheck": "pnpm typecheck:ts && pnpm typecheck:gui",
    "typecheck:ts": "tsc --project tsconfig.json --noEmit",
    "typecheck:gui": "tsc --project tsconfig.gui.json --noEmit",
    "dev:gui": "next dev",
    "dev:admin": "next dev",
    "build:gui": "next build",
    "build:admin": "next build",
    "start:gui": "next start",
    "start:admin": "next start",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "minisearch": "^7.2.0",
    "next": "^16.2.7",
    "next-sanity": "^11.6.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^5.30.0",
    "server-only": "^0.0.1",
    "styled-components": "^6.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.6.5",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-language-server": "^5.3.0"
  }
}
